PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SANDBOX_SECRET=your-plaid-sandbox-secret

# Optional. Lets curl/local tests use a fixed bearer token in non-production.
DEV_BEARER_TOKEN=local-dev-bearer-token-at-least-16-chars

# Optional. Set only when testing OAuth redirect behavior against a registered URI.
PLAID_REDIRECT_URI=https://budgettracer-plaid-relay-dev.your-account.workers.dev/plaid/oauth
